# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=realestate
DB_USER=postgres
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-256-bit-secret-here
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# App
APP_ENV=development
PORT=8080

# Google Maps — server-side key (Phase 3)
# Restricted to Geocoding API only. Used by the share endpoint for reverse geocoding.
# Separate from the client-side key passed via --dart-define=GOOGLE_MAPS_API_KEY to Flutter.
# Optional: if missing, share endpoint returns "Location available on request".
GOOGLE_MAPS_API_KEY=

# Twilio — WhatsApp & SMS dispatch (Phase 4)
# All four required for notification dispatch. Leave blank to disable sending
# (worker will log and mark jobs FAILED instead of calling Twilio).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+14155238886

# Google Cloud Vision — OCR autofill (Phase 4)
# Set to "true" to enable. Requires the Cloud Vision API to be enabled in your
# GCP project. Uses the same Application Default Credentials as GCS — no
# separate key file needed.
GOOGLE_VISION_ENABLED=false

# Google Cloud Storage (Phase 2)
GCS_BUCKET=your-bucket-name
GCS_CDN_BASE_URL=https://storage.googleapis.com/your-bucket-name
# For local dev, point this to your downloaded service account JSON key.
# In production on GCE/Cloud Run, remove entirely — Workload Identity handles auth via ADC.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json

# Rate limiting (Phase 5) — requests per window per IP.
# Defaults are used if these are not set.
RATE_LIMIT_AUTH_LOGIN=10
RATE_LIMIT_AUTH_REGISTER=5
RATE_LIMIT_AUTH_REFRESH=30
RATE_LIMIT_OCR_SCAN=20
RATE_LIMIT_GLOBAL=300
